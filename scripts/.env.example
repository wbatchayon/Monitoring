# Environment variables for Monitoring Infrastructure
# Copy to .env and customize for your environment

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# Monitoring network CIDR (for firewall rules)
export MONITORING_NETWORK="192.168.1.0/24"

# Default gateway
export GATEWAY="192.168.1.1"

# =============================================================================
# SERVICE IP ADDRESSES
# =============================================================================

# VM IP addresses (last octet - e.g., 110 = 192.168.1.110)
export PROMETHEUS_IP="192.168.1.110"
export ELK_IP="192.168.1.111"
export GRAFANA_IP="192.168.1.112"
export ZABBIX_IP="192.168.1.113"

# =============================================================================
# SERVICE PORTS
# =============================================================================

# Prometheus
export PROMETHEUS_PORT="9090"
export NODE_EXPORTER_PORT="9100"
export PUSHGATEWAY_PORT="9091"

# ELK Stack
export ELASTICSEARCH_PORT="9200"
export KIBANA_PORT="5601"
export LOGSTASH_PORT="5044"

# Grafana
export GRAFANA_PORT="3000"

# Zabbix
export ZABBIX_PORT="8080"
export ZABBIX_AGENT_PORT="10050"
export ZABBIX_SERVER_PORT="10051"

# =============================================================================
# TERRAFORM CONFIGURATION (for Proxmox)
# =============================================================================

# Proxmox API URL
export TF_VAR_proxmox_api_url="https://proxmox.local:8006/api2/json"

# Proxmox API Token (generate in Proxmox web UI)
export TF_VAR_proxmox_api_token_id="root@pam!terraform"
export TF_VAR_proxmox_api_token_secret="your-secret-token-here"

# VM Password (for cloud-init, min 8 characters)
export TF_VAR_vm_password=""

# Proxmox SSH (optional, for validation)
export TF_VAR_proxmox_ssh_user="root"
export TF_VAR_proxmox_ssh_password=""

# Proxmox Node Name
export TF_VAR_proxmox_node="pve"

# Proxmox Storage
export TF_VAR_proxmox_storage="local-lvm"

# Base VM ID (VMs will be ID, ID+1, ID+2, ID+3)
export TF_VAR_proxmox_vm_id="9000"

# SSH Public Key Path
export TF_VAR_ssh_public_key_path="~/.ssh/id_rsa.pub"

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# SSH Access (CIDR for firewall)
export TF_VAR_allowed_ssh_cidr="192.168.1.0/24"

# Enable security features
export TF_VAR_enable_firewall="true"
export TF_VAR_enable_fail2ban="true"
export TF_VAR_enable_auto_updates="true"
