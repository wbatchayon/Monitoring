# Zabbix Agent Configuration
# Managed by Ansible

Server={{ zabbix_server_ip | default('127.0.0.1') }}
ServerActive={{ zabbix_server_ip | default('127.0.0.1') }}
Hostname={{ inventory_hostname }}

ListenPort=10050
ListenIP=0.0.0.0

RefreshActiveChecks=60
BufferSend=5
BufferSize=100
MaxLinesPerSecond=20

Timeout=30

AllowRoot=0

ServerActive=127.0.0.1

Include=/etc/zabbix/zabbix_agentd.d/*.conf
