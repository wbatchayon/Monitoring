# Kibana Configuration
# Managed by Ansible

server.host: "0.0.0.0"
server.port: 5601

elasticsearch.hosts: ["http://{{ elk_ip | default('192.168.1.111') }}:9200"]

# Elasticsearch request timeout
elasticsearch.requestTimeout: 60000

# Enable optimizations
csp.strict: true
csp.warnLegacyBrowsers: false
